# =============================================================
# PredictKit — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================

# ── Supabase (required) ───────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── SECURITY NOTES ────────────────────────────────────────────
# • Do NOT add GEMINI_API_KEY or any other secret here.
#   Vite bundles ALL VITE_* vars into the client JS — they are
#   publicly readable by anyone who views the page source.
# • Admin accounts must be created via Supabase Dashboard and
#   their role set to 'ADMIN' in the profiles table directly.
#   Never store admin passwords in environment variables.
